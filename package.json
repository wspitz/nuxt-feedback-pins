{
  "name": "nuxt-feedback-pins",
  "version": "0.1.1",
  "description": "Visual feedback pins for Nuxt prototypes — let clients comment directly on the page, Figma-style.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wspitz/nuxt-feedback-pins.git"
  },
  "bugs": {
    "url": "https://github.com/wspitz/nuxt-feedback-pins/issues"
  },
  "homepage": "https://github.com/wspitz/nuxt-feedback-pins#readme",
